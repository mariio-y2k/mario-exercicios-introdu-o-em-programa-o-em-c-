Crie um programa que calcule a média de duas notas e exiba o resultado. 

 float n1, n2, n3, n4, media;
 printf("Digite quatro notas: ");
 scanf("%f %f %f %f", &n1, &n2, &n3, &n4);
 media = (n1 + n2 + n3 + n4) / 4;
 printf("Media: %.2f\n", media); 
 
 if (media >= 7.0) 
        printf("Resultado: Aprovado!\n");
    else 
        printf("Resultado: Recuperacao.\n");
