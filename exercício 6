Crie um programa que:
 Leia um número inteiro
 Verifique:
  Se é par ou ímpar
  Se é positivo ou negativo 

  int num;
 
 printf("Digite um numero: ");
 scanf("%d", &num);
 
 if (num % 2 == 0) 
 printf("Par\n");
 
 else
 printf("Impar\n");
 
 if (num >= 0) 
 printf("Positivo\n");
 
 else
 printf("Negativo\n");
 
   return 0;
